    {
      "parameters": {
        "jsCode": "// Usamos $input.all() para obtener todos los registros del nodo anterior\nreturn $input.all().map(item => {\n  const row = item.json;\n\n  // Concatenamos las descripciones largas en un solo bloque para la columna \"info\"\n  // Usamos la sintaxis de corchetes [''] porque los nombres del Excel tienen espacios y paréntesis\n  const info_completa = `\nOBJETIVO: ${row['Descripción del Objetivo Pedagógico (Min 1000 caracteres)'] || ''}\n\nACTIVIDAD: ${row['Descripción de la Actividad (Min 100 caracteres)'] || ''}\n\nDETALLES: ${row['Descripción de lo acontecido durante la actividad (Min 800 caracteres)'] || ''}\n\nLOGROS: ${row['Resultados y logros alcanzados (Min 100 caracteres)'] || ''}\n  `.trim();\n\n  // Devolvemos el objeto con los nombres de columna limpios para Supabase\n  return {\n      id: row['CODIGO_MATERIA'], \n      electiva_codigo: row['CODIGO_MATERIA'],\n      info: info_completa,\n      evidence_url: row['Evidencias Visuales y Testimonios (Fotos y/o Video)'],\n      blog_url: row['URL Blog']\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
