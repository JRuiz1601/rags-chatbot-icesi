      "parameters": {
        "jsCode": "const evaluaciones = $input.all().map(i => i.json);\n\n// Traer la electiva del nodo anterior\nconst electiva = $('Get many rows').first().json;\n\nreturn [{\n  json: {\n    ...electiva,\n    evaluaciones: evaluaciones.length > 0 ? evaluaciones : null\n  }\n}];"
