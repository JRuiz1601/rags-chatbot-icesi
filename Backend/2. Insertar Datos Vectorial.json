    {
      "parameters": {
        "jsCode": "const evaluaciones = $input.all().map(i => i.json);\n\n// Agrupar por electiva_nrc\nconst grouped = {};\nevaluaciones.forEach(ev => {\n  const nrc = ev.electiva_nrc;\n  if (!grouped[nrc]) grouped[nrc] = [];\n  grouped[nrc].push({\n    nombre: ev.nombre,\n    porcentaje: ev.porcentaje,\n    descripcion: ev.descripcion,\n    codigo_evaluacion: ev.codigo_evaluacion\n  });\n});\n\n// Devolver un item por NRC\nreturn Object.entries(grouped).map(([nrc, evals]) => ({\n  json: {\n    electiva_nrc: parseInt(nrc),\n    evaluaciones: evals\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        1520
      ],
      "id": "cc44251d-c146-4306-84a1-b18e2e3bce2b",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst batches = [];\n\n// Traer electivas del primer nodo para cruzar metadata\nconst electivas = $('Get many rows').all().map(i => i.json);\n\nitems.forEach(item => {\n  const { electiva_nrc, evaluaciones } = item.json;\n  \n  // Buscar la electiva correspondiente por nrc\n  const electiva = electivas.find(e => e.nrc === electiva_nrc);\n  if (!electiva) return;\n\nbatches.push({\n    json: {\n      text: JSON.stringify(evaluaciones),\n      metadata: {\n        codigo_electiva: electiva.codigo,\n        nombre_electiva: electiva.nombre,\n        creditos: electiva.creditos,\n        modalidad: electiva.modalidad,\n        departamento: electiva.departamento,\n        periodo_academico: electiva.periodo_academico,\n        tipo_contenido: 'evaluacion'\n      }\n    }\n  });\n});\n\nreturn batches;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -192,
        1520
      ],
      "id": "fc6b41ac-e994-4b8f-ba57-7a5f5b9e13d0",
      "name": "Code in JavaScript2"
    }
