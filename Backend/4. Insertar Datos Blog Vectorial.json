    {
      "parameters": {
        "jsCode": "// 1. Obtenemos los datos de los dos nodos anteriores (del Merge)\n// Input 1: Datos del Blog (procesados por Code in JavaScript1)\n// Input 2: Datos de Electivas (de Supabase)\nconst blogs = $input.all()[0].json.data || $items(\"Code in JavaScript1\"); \nconst electivas = $input.all()[1]?.json.data || $items(\"Get many rows\");\n\n// NOTA: En n8n moderno, $input.all() en un nodo Merge suele traer todo mezclado.\n// Para ir a la segura, usamos $items() refiriéndonos al nombre del nodo anterior.\nconst blogsData = $items(\"Code in JavaScript1\").map(item => item.json);\nconst electivasData = $items(\"Get many rows\").map(item => item.json);\n\nconst resultados = [];\n\n// 2. Recorremos cada entrada del blog\nfor (const blog of blogsData) {\n  \n  // 3. Buscamos la electiva correspondiente en el array de electivas\n  // La llave común es el código. En el blog se llama 'electiva_codigo' y en electivas 'codigo'.\n  // Usamos trim() para evitar errores por espacios en blanco invisibles.\n  const electivaMatch = electivasData.find(e => e.codigo.trim() === blog.electiva_codigo.trim());\n\n  if (electivaMatch) {\n    // 4. Si hay match, construimos el objeto enriquecido\n    \n    // Preparamos la metadata base (igual que en tus otros chunks)\n    const metadata = {\n      codigo_electiva: electivaMatch.codigo,\n      nombre_electiva: electivaMatch.nombre,\n      creditos: electivaMatch.creditos,\n      modalidad: electivaMatch.modalidad,\n      departamento: electivaMatch.departamento,\n      periodo_academico: electivaMatch.periodo_academico,\n      \n      // Agregamos los campos específicos de este tipo de chunk\n      tipo_contenido: 'experiencia_real', // <--- CLAVE para tu filtro\n    };\n\n    // 5. Creamos el objeto final para el Vector Store\n    resultados.push({\n      json: {\n        text: blog.info, // El texto largo concatenado del blog\n        metadata: metadata\n      }\n    });\n  } else {\n    // Opcional: Loguear si algún blog no encontró su electiva (por si hay errores de código)\n    console.log(`No se encontró electiva para el código: ${blog.electiva_codigo}`);\n  }\n}\n\nreturn resultados;\n\n"
      },
