    {
      "parameters": {
        "jsCode": "// ============================================\n// GENERAR CHUNKS POR ELECTIVA (Sin Evaluaciones)\n// Versión: Supabase adaptada - Sin JOINs\n// ============================================\n\nconst electivas = $input.all();\nconst batches = [];\n\nconsole.log(`=== PROCESANDO ${electivas.length} ELECTIVAS ===`);\n\nelectivas.forEach((electiva, index) => {\n  const e = electiva.json;\n  \n  const baseMetadata = {\n    codigo_electiva: e.codigo,\n    nombre_electiva: e.nombre,\n    creditos: e.creditos,\n    modalidad: e.modalidad,\n    departamento: e.departamento,\n    periodo_academico: e.periodo_academico\n  };\n  \n  // BATCH 1: Información General\n  batches.push({\n    json: {\n      text: `${e.nombre}. ${e.objetivo_general || ''} Modalidad: ${e.modalidad}. Créditos: ${e.creditos}.`,\n      metadata: {\n        ...baseMetadata,\n        tipo_contenido: 'info_general'\n      }\n    }\n  });\n  \n  // BATCH 2: Objetivo General\n  if (e.objetivo_general) {\n    batches.push({\n      json: {\n        text: e.objetivo_general,\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'objetivo_general'\n        }\n      }\n    });\n  }\n  \n  // BATCH 3: Metodología\n  if (e.metodologia) {\n    batches.push({\n      json: {\n        text: e.metodologia,\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'metodologia'\n        }\n      }\n    });\n  }\n  \n  // BATCH 4: Competencias (JSON → necesita procesamiento LLM)\n  if (e.competencias) {\n    batches.push({\n      json: {\n        text: JSON.stringify(e.competencias),\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'competencias'\n        }\n      }\n    });\n  }\n  \n  // BATCH 5: Resultados de Aprendizaje (JSON → necesita procesamiento LLM)\n  if (e.resultados_aprendizaje) {\n    batches.push({\n      json: {\n        text: JSON.stringify(e.resultados_aprendizaje),\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'resultados_aprendizaje'\n        }\n      }\n    });\n  }\n  \n  // BATCH 6: Actividades del Estudiante (JSON → necesita procesamiento LLM)\n  if (e.actividades_estudiante) {\n    batches.push({\n      json: {\n        text: JSON.stringify(e.actividades_estudiante),\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'actividades_estudiante'\n        }\n      }\n    });\n  }\n  \n  // BATCH 7: Unidades de Aprendizaje (JSON → necesita procesamiento LLM)\n  if (e.unidades_aprendizaje) {\n    batches.push({\n      json: {\n        text: JSON.stringify(e.unidades_aprendizaje),\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'unidades_aprendizaje'\n        }\n      }\n    });\n  }\n\n  // BATCH 8: Evaluación\n  if (e.evaluaciones && e.evaluaciones.length > 0) {\n    batches.push({\n      json: {\n        text: JSON.stringify(e.evaluaciones),\n        metadata: {\n          ...baseMetadata,\n          tipo_contenido: 'evaluacion'\n        }\n      }\n    });\n  }\n});\n\nreturn batches;\n\n"
      },
